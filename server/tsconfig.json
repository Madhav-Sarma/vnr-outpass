{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": false,
    "typeRoots": ["./types", "./node_modules/@types"],
    "types": ["node", "express"],
    "resolveJsonModule": true,                 // ✅ Add if you import .json files
    "skipLibCheck": true                       // ✅ Optional: avoids type issues from node_modules
  },
  "include": ["src"],                          // ✅ Ensures only /src is compiled
  "exclude": ["node_modules", "dist"]          // ✅ Prevents accidental recursion
}